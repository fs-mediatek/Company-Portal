# Copy this file to .env.local and fill in the real values
# Location on server: /var/www/company-portal/.env.local

# ── Facility Management DB ───────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=facility_mgmt
DB_USER=portal_app
DB_PASSWORD=CHANGE_ME

# ── Core Portal DB ───────────────────────────────────────────────────────────
CORE_DB_HOST=127.0.0.1
CORE_DB_NAME=portal_core
CORE_DB_USER=portal_app
CORE_DB_PASSWORD=CHANGE_ME

# ── Helpdesk DB ──────────────────────────────────────────────────────────────
HELPDESK_DB_HOST=127.0.0.1
HELPDESK_DB_NAME=helpdesk
HELPDESK_DB_USER=portal_app
HELPDESK_DB_PASSWORD=CHANGE_ME

# ── App ──────────────────────────────────────────────────────────────────────
APP_SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
